# Hotdeal API Configuration
# ⚠️ SECURITY: NEVER commit the actual .env file to version control
# ⚠️ SECURITY: NEVER hardcode these values in your source code
# ⚠️ SECURITY: NEVER share or display .env file contents
#
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual API keys and secrets
# 3. Keep .env in .gitignore (already configured)
# 4. Run: npm run security:setup-hooks (to install security checks)

# ============================================================================
# FIREBASE CONFIGURATION
# Get these from: https://console.firebase.google.com/project/YOUR_PROJECT/settings/general
# ============================================================================
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id_here
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
FIREBASE_APP_ID=your_app_id_here

# Firestore credentials (for Node.js server-side operations)
# Download from Firebase Console -> Service Accounts -> Generate new private key
FIRESTORE_CREDENTIALS_JSON=/path/to/firebase-credentials.json

# ============================================================================
# AUTHENTICATION
# Magic Link for passwordless login
# ============================================================================
MAGIC_AUTH_API_KEY=your_magic_api_key_here
MAGIC_AUTH_ENDPOINT=https://your-api-endpoint.com/api/magic-auth
MAGIC_AUTH_SECRET=your_magic_secret_here

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
# Web Scraping (if using)
SCRAPER_API_KEY=your_scraper_api_key_here
SCRAPER_ENDPOINT=https://api.example.com/scrape

# Redis (Upstash for serverless)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# ============================================================================
# DEPLOYMENT & CI/CD
# ============================================================================
# Vercel deployment token (from: https://vercel.com/account/tokens)
VERCEL_TOKEN=your_vercel_token_here
VERCEL_ORG_ID=your_org_id_here
VERCEL_PROJECT_ID=your_project_id_here

# GitHub token (for automated commits)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Vercel deploy hook (optional, for automatic deployments)
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/prj_xxx/hook_xxx

# ============================================================================
# ENVIRONMENT & FEATURE FLAGS
# ============================================================================
NODE_ENV=production
# Valid values: development, production, test

ENABLE_DEAL_CACHE=true
CACHE_TTL_MS=3600000  # 1 hour

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# RATE LIMITING & SECURITY
# ============================================================================
RATE_LIMIT_WINDOW_MS=60000    # 1 minute
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10

# CORS allowed origins (comma-separated for multiple environments)
CORS_ORIGINS=https://jachwi-hotdeal.vercel.app,https://hotdeal.kr

# ============================================================================
# OPTIONAL: LOCAL DEVELOPMENT OVERRIDES
# ============================================================================
# Local API endpoint (for testing)
# LOCAL_API_URL=http://localhost:3000

# Test Google account (for development only, NEVER in production)
# TEST_GOOGLE_EMAIL=test@example.com
# TEST_GOOGLE_PASSWORD=testing123  (NOT RECOMMENDED - use test doubles instead)

# ============================================================================
# SECURITY REMINDERS
# ============================================================================
# ✅ DO:
#    - Use environment variables for all secrets
#    - Rotate API keys monthly
#    - Use .env.example as template
#    - Add .env to .gitignore (already done)
#    - Use strong, randomly generated tokens (not "password123")
#
# ❌ DON'T:
#    - Hardcode API keys in source code
#    - Share .env file on Slack, email, or chat
#    - Commit .env to version control
#    - Log or console.log API keys
#    - Use test passwords in production
#    - Leave secrets in commented code
#
# 🔒 SECURITY CHECKS:
#    Pre-commit hook: javascript scripts/check-secrets.sh
#    Pre-push hook:   scripts/check-push.sh
#    Audit:           npm audit
#    Manual check:    grep -r "VERCEL_TOKEN\|FIREBASE_API_KEY" --include="*.js" --include="*.json"

