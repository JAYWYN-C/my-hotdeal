# npm Security Configuration

# Audit configuration
audit=true
audit-level=high

# Verify package integrity
verify-store-integrity=true

# Use exact versions
save-exact=false

# Enable strict mode
ignore-scripts=false

# Production mode
production=false

# Legacy peer deps handling
legacy-peer-deps=false

# Registry
registry=https://registry.npmjs.org/

# Security
// Prevent installation of packages with critical vulnerabilities
// Set to either 'audit' (default), 'ignore'
force-auth=legacy
