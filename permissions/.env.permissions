# Hotdeal .env File Access Control Rules
# ============================================================================
# Defines which processes/roles can access the .env file
# Format: TARGET PERMISSION [CONDITIONS] [ACTION]
#
# Purpose: Enforce minimal access principle for sensitive configuration
# Last Updated: 2026-04-02
# Reviewer: Hotdeal Security Team
# ============================================================================

# ============================================================================
# PART 1: DENY RULES (Most Restrictive First)
# ============================================================================
# All rules processed top-to-bottom; first match wins

# 1.1 Direct File Access Restrictions
# ============================================================================

# DENY: Direct reads/writes on .env file by ANY process
.env             DENY  process=all
.env.local       DENY  process=all
.env.*.local     DENY  process=all
.env.*           DENY  process=all

# DENY: File operations
.env             DENY  operation=cat
.env             DENY  operation=less
.env             DENY  operation=more
.env             DENY  operation=tail
.env             DENY  operation=head
.env             DENY  operation=grep
.env             DENY  operation=sed
.env             DENY  operation=awk


# 1.2 Version Control Restrictions
# ============================================================================

# DENY: Git operations on .env
.env             DENY  git-add
.env             DENY  git-commit
.env             DENY  git-stage
.env             DENY  git-status      # Hide .env from `git status`

# DENY: VCS check-ins
.env             DENY  vcs-checkin
.env             DENY  git-push
.env             DENY  git-pull
.env             DENY  hg-commit
.env             DENY  svn-add


# 1.3 AI & Automated Access Restrictions (CRITICAL)
# ============================================================================

# DENY: AI model context loading
.env             DENY  model-context-protocol
.env             DENY  claude-context
.env             DENY  copilot-context
.env             DENY  ai-agent-read
.env             DENY  llm-embedding
.env             DENY  vector-search

# DENY: LLM/ML pipeline access
.env             DENY  ml-training
.env             DENY  embeddings
.env             DENY  rag-indexing

# DENY: Data exfiltration attempts
.env             DENY  curl
.env             DENY  wget
.env             DENY  nc  # netcat
.env             DENY  dd


# 1.4 File Watching & Monitoring Restrictions
# ============================================================================

# DENY: Automatic file watchers
.env             DENY  file-watcher
.env             DENY  file-monitor
.env             DENY  chokidar
.env             DENY  nodemon
.env             DENY  watchman
.env             DENY  inotify

# DENY: Development servers
.env             DENY  webpack-dev-server
.env             DENY  vite-dev-server


# 1.5 IDE & Editor Restrictions
# ============================================================================

# DENY: IDE access to .env
.env             DENY  vscode
.env             DENY  intellij
.env             DENY  sublime
.env             DENY  vim
.env             DENY  nano
.env             DENY  emacs

# DENY: IDE plugins/extensions
.env             DENY  extension=*


# 1.6 CI/CD Pipeline Restrictions (Specific)
# ============================================================================

# DENY: Direct CI/CD file access
.env             DENY  ci=github-actions FILE_OP=read MODE=direct
.env             DENY  ci=circleci FILE_OP=read MODE=direct
.env             DENY  ci=travis FILE_OP=read MODE=direct


# ============================================================================
# PART 2: ALLOW RULES (Minimal, Specific Access)
# ============================================================================
# Processed AFTER deny rules; explicitly limited

# 2.1 Runtime Access via dotenv Library
# ============================================================================

# ALLOW: JavaScript/Node.js runtime (via dotenv module)
.env             ALLOW  process=node language=javascript module=dotenv METHOD=require
.env             ALLOW  process=npm language=javascript module=dotenv METHOD=import

# ALLOW: Python runtime (via python-dotenv)
.env             ALLOW  process=python language=python module=dotenv METHOD=load_dotenv

# ALLOW: Build process (npm/yarn/pnpm)
.env             ALLOW  process=npm CONTEXT=build
.env             ALLOW  process=yarn CONTEXT=build
.env             ALLOW  process=pnpm CONTEXT=build


# 2.2 Development Server Access
# ============================================================================

# ALLOW: Local dev server ONLY (not production)
.env             ALLOW  process=npm SCRIPT=dev ENVIRONMENT=local
.env             ALLOW  process=npm SCRIPT=start ENVIRONMENT=development


# 2.3 Deployment Pipeline Access
# ============================================================================

# ALLOW: Vercel deployment (server-side only)
.env             ALLOW  process=vercel CONTEXT=build ENVIRONMENT=vercel
.env             ALLOW  platform=vercel PHASE=build runner=ubuntu-latest

# ALLOW: GitHub Actions (restricted to specific runners)
.env             ALLOW  ci=github-actions RUNNER=ubuntu-latest BRANCH=main
.env             ALLOW  ci=github-actions JOB=collect-deals ENVIRONMENT=production


# 2.4 Testing Context
# ============================================================================

# ALLOW: Test runner (npm test)
.env             ALLOW  process=npm SCRIPT=test ENVIRONMENT=test MODE=isolated
.env             ALLOW  process=jest ENVIRONMENT=test


# ============================================================================
# PART 3: AUDIT LOGGING
# ============================================================================

# Log all attempts (allowed or denied)
.env             LOG    action=read   level=info
.env             LOG    action=write  level=critical
.env             LOG    action=execute level=critical
.env             LOG    action=access level=warning

# Log suspicious patterns
.env             LOG    pattern=DENY level=warning format=VIOLATION
.env             LOG    pattern=ALLOW level=info format=ACCESS_GRANTED


# ============================================================================
# PART 4: RELATED CREDENTIAL FILES
# ============================================================================

# Deny access to Firebase credentials
firebase-config.js            DENY  *
firebase-credentials.json     DENY  *
firebase-config.*.json        DENY  *

# Deny access to sensitive template files
*credentials*.template.*      DENY  *
*secrets*.template.*          DENY  *
*secret*.json                 DENY  *

# ============================================================================
# PART 5: IMPLEMENTATION STRATEGY
# ============================================================================
#
# LAYER 1: File System Permissions
# ============================================================================
# Command: chmod 600 .env
# Result:  -rw------- (owner read/write only)
#
# Verification:
#   ls -la .env
#   stat .env
#
#
# LAYER 2: Git Pre-Commit Hook
# ============================================================================
# Location: .git/hooks/pre-commit
# Action:   Blocks staging of .env file
# Trigger:  Before each `git commit`
#
# Installation: npm run security:setup-hooks
# Script:       scripts/check-secrets.sh
#
# Test:
#   git add .env
#   git commit -m "test" # Should FAIL
#
#
# LAYER 3: Git Pre-Push Hook
# ============================================================================
# Location: .git/hooks/pre-push
# Action:   Verifies .env is not in commits
# Trigger:  Before each `git push`
# Script:   scripts/check-push.sh
#
#
# LAYER 4: Node.js Module Wrapper (Future)
# ============================================================================
# Goal: Override require('fs') for .env access
# Approach: Create wrapper that validates access context
#
# Example:
#   // In app initialization
#   require('./lib/env-access-control.js');
#   // Now, fs.readFile('.env') throws error
#   // But require('dotenv').config() works
#
#
# LAYER 5: IDE/Editor Configuration
# ============================================================================
# Add to .vscode/settings.json:
# {
#   "files.exclude": {
#     ".env": true,
#     ".env.*": true,
#     "*credentials*": true
#   },
#   "search.exclude": {
#     ".env": true,
#     ".env.*": true
#   }
# }
#
#
# LAYER 6: CI/CD Secret Management
# ============================================================================
# GitHub Secrets (NOT as file):
#   - Set: Settings -> Secrets -> New repository secret
#   - Use: ${{ secrets.FIREBASE_API_KEY }}
#
# Vercel Secrets:
#   - Set: Settings -> Environment Variables
#   - Use: process.env.FIREBASE_API_KEY
#
# Do NOT:
#   - Store .env file as artifact
#   - Pass .env as container mount
#   - Export .env to logs
#
#
# LAYER 7: Audit Trail
# ============================================================================
# Log file: .env-access-audit.log
# Format:
#   [2026-04-02 10:15:30] DENIED  read   .env    by=grep      ip=127.0.0.1
#   [2026-04-02 10:15:31] DENIED  read   .env    by=cat       ip=127.0.0.1
#   [2026-04-02 10:16:00] ALLOWED read   .env    by=node      context=build
#
# Review: Weekly audit of DENIED attempts
#
#
# ============================================================================
# PART 6: VIOLATION RESPONSE
# ============================================================================
#
# If .env is ACCIDENTALLY committed:
#
# 1. IMMEDIATE (within 1 hour)
#    - All API keys must be regenerated
#    - Git history scrubbed (git filter-branch or BFG)
#    - Force push: git push --force-with-lease
#
# 2. NOTIFICATION (same day)
#    - Notify all API key owners
#    - File incident report
#    - Document in audit log
#
# 3. PREVENTION (within 24 hours)
#    - Verify git hooks installed
#    - Run: npm run security:setup-hooks
#    - Test pre-commit with: git add .env
#
# 4. ESCALATION (if needed)
#    - Contact security team
#    - Review third-party access logs
#    - Monitor for unauthorized usage
#
#
# ============================================================================
# PART 7: COMPLIANCE CHECKLIST
# ============================================================================
#
# [ ] .env file exists
# [ ] .env is in .gitignore (multiple patterns)
# [ ] .env permissions set to 600 (chmod 600 .env)
# [ ] .gitignore includes .env.*, *credentials*, *secrets*
# [ ] Pre-commit hook installed and working
# [ ] Pre-push hook installed and working
# [ ] Audit log reviewed within last 30 days
# [ ] All API keys rotated within last 90 days
# [ ] No .env* files in git history (check: git log --all --full-history -p .env)
# [ ] CI/CD uses GitHub Secrets / Vercel variables (not .env file)
# [ ] IDE is configured to hide .env (.vscode/settings.json)
# [ ] All developers trained on .env security
# [ ] Security scan passed (npm audit, etc.)
#
#
# ============================================================================
# VERSION HISTORY
# ============================================================================
# 2026-04-02 - Initial creation (v1.0)
#              - Added comprehensive DENY/ALLOW rules
#              - Added implementation layers
#              - Added compliance checklist
